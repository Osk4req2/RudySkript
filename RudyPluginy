<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>RudyPlugins</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Inter:wght@400;500;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
          --line: rgba(255,255,255,0.08);
          --text: #f7f1ff;
          --muted: #c5b6db;
          --violet-soft: #e4c0ff;
          --shadow: 0 24px 70px rgba(0,0,0,0.45);
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; }

        body {
          font-family: 'Inter', sans-serif;
          color: var(--text);
          background:
            radial-gradient(circle at 20% 0%, rgba(187,114,255,0.18), transparent 35%),
            radial-gradient(circle at 80% 0%, rgba(112,35,224,0.18), transparent 35%),
            linear-gradient(180deg, #05030a, #090512 60%, #04020a);
          min-height: 100vh;
          overflow-x: hidden;
          position: relative;
        }

        body::before {
          content: "";
          position: fixed;
          inset: 0;
          background-image:
            linear-gradient(rgba(255,255,255,0.022) 1px, transparent 1px),
            linear-gradient(90deg, rgba(255,255,255,0.022) 1px, transparent 1px);
          background-size: 34px 34px;
          opacity: 0.22;
          pointer-events: none;
        }

        .container {
          width: min(1240px, calc(100% - 32px));
          margin: 0 auto;
        }

        .pixel {
          font-family: 'Press Start 2P', cursive;
          line-height: 1.45;
        }

        .muted { color: var(--muted); }

        header {
          position: sticky;
          top: 0;
          z-index: 60;
          backdrop-filter: blur(16px);
          background: rgba(9, 6, 16, 0.82);
          border-bottom: 1px solid rgba(255,255,255,0.06);
          box-shadow: 0 8px 30px rgba(0,0,0,0.18);
        }

        .nav {
          display: flex;
          align-items: center;
          justify-content: space-between;
          padding: 18px 0;
          gap: 16px;
        }

        .brand {
          display: flex;
          align-items: center;
          gap: 14px;
          text-decoration: none;
          color: var(--text);
        }

        .logo-box {
          width: 52px;
          height: 52px;
          border: 3px solid #241237;
          border-radius: 14px;
          background: linear-gradient(180deg, #cb8cff 0 34%, #8b3fff 34% 60%, #1b1327 60% 100%);
          box-shadow: inset -4px -4px 0 rgba(0,0,0,0.24), inset 4px 4px 0 rgba(255,255,255,0.08), 0 10px 25px rgba(0,0,0,0.28);
          position: relative;
        }

        .logo-box::after {
          content: "";
          position: absolute;
          inset: 8px;
          border: 2px solid rgba(255,255,255,0.12);
          border-radius: 8px;
        }

        .brand strong { display: block; font-size: 0.95rem; }
        .brand span { color: var(--muted); font-size: 0.88rem; }

        .nav-links {
          display: flex;
          gap: 12px;
          flex-wrap: wrap;
          align-items: center;
          margin-left: auto;
          padding-right: 170px;
        }

        .nav-links a {
          text-decoration: none;
          color: var(--text);
          font-weight: 700;
          padding: 10px 14px;
          border-radius: 14px;
          transition: 0.22s ease;
          border: 1px solid transparent;
        }

        .nav-links a:hover {
          background: rgba(255,255,255,0.045);
          border-color: var(--line);
        }

        .btn {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          gap: 10px;
          padding: 14px 20px;
          border-radius: 16px;
          text-decoration: none;
          font-weight: 800;
          letter-spacing: 0.01em;
          transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
          box-shadow: var(--shadow);
          border: 1px solid transparent;
          cursor: pointer;
          font: inherit;
        }

        .btn:hover { transform: translateY(-2px); filter: brightness(1.03); }

        .btn-primary {
          background: linear-gradient(180deg, #d692ff 0%, #a54bff 52%, #6d22da 100%);
          color: #12071d;
          border-color: rgba(255,255,255,0.18);
        }

        .btn-secondary {
          background: linear-gradient(180deg, #efc6ff 0%, #c17cff 100%);
          color: #1a0d25;
          border-color: rgba(255,255,255,0.18);
        }

        .btn-dark {
          background: linear-gradient(180deg, rgba(28,18,43,0.98) 0%, rgba(15,10,24,0.98) 100%);
          color: var(--text);
          border-color: var(--line);
        }

        .status-topbar {
          width: 100%;
          background: linear-gradient(90deg, #6d22da, #a54bff);
          text-align: center;
          padding: 8px 0;
          font-weight: 700;
          font-size: 0.9rem;
          box-shadow: 0 8px 20px rgba(112,35,224,0.2);
        }

        .hero, section { padding: 56px 0; }

        .hero {
          padding-top: 90px;
          min-height: 82vh;
          display: flex;
          align-items: center;
          position: relative;
          overflow: hidden;
        }

        .hero-grid,
        .payments-grid,
        .why-grid,
        .footer-grid,
        .shop-grid,
        .cta-box {
          display: grid;
          gap: 22px;
        }

        .hero-grid {
          grid-template-columns: 1fr 1fr;
          align-items: center;
        }

        .hero-grid > div:first-child {
          display: flex;
          flex-direction: column;
          justify-content: center;
          align-items: flex-start;
          padding-left: 60px;
        }

        .tag {
          display: inline-flex;
          align-items: center;
          gap: 10px;
          padding: 10px 14px;
          border-radius: 999px;
          background: rgba(170, 91, 255, 0.12);
          color: #f0d1ff;
          border: 1px solid rgba(170, 91, 255, 0.26);
          margin-bottom: 18px;
          font-weight: 700;
        }

        h1 {
          font-size: clamp(1.8rem, 4.6vw, 3.6rem);
          line-height: 1.08;
          margin-bottom: 18px;
          text-align: left;
          max-width: 10ch;
          text-shadow: 0 0 20px rgba(187,114,255,0.5);
        }

        .hero-actions,
        .trust-bar,
        .shop-tabs,
        .shop-filters {
          display: flex;
          gap: 14px;
          flex-wrap: wrap;
        }

        .section-title {
          margin-bottom: 20px;
          display: flex;
          flex-direction: column;
          align-items: center;
          text-align: center;
        }

        .section-title h2 {
          font-size: clamp(1.7rem, 4vw, 3rem);
          margin-bottom: 10px;
          letter-spacing: -0.02em;
          width: 100%;
        }

        .section-lead {
          color: var(--muted);
          font-size: 1.05rem;
          line-height: 1.8;
          max-width: 700px;
          margin: 0 auto;
          text-align: center;
        }

        .hero-card,
        .pay-card,
        .card,
        .contact-card,
        .shop-shell,
        .shop-product {
          background: linear-gradient(180deg, rgba(24,16,38,0.94), rgba(10,7,18,0.98));
          border: 1px solid var(--line);
          border-radius: 28px;
          box-shadow: var(--shadow);
          backdrop-filter: blur(14px);
        }

        .hero-card {
          padding: 24px;
          overflow: hidden;
          position: relative;
          margin-left: 40px;
        }

        .payments-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
          gap: 22px;
          align-items: stretch;
        }

        .pay-card,
        .card,
        .contact-card {
          padding: 30px;
          transition: 0.25s ease;
        }

        .pay-card h3,
        .card h3,
        .shop-product h3 {
          font-size: 1.2rem;
          margin-bottom: 10px;
        }

        .pay-card p,
        .card p,
        .shop-product p {
          color: var(--muted);
          line-height: 1.7;
          margin-bottom: 10px;
        }

        .pay-card:hover,
        .card:hover,
        .contact-card:hover,
        .shop-product:hover {
          transform: translateY(-6px);
          border-color: rgba(187,114,255,0.32);
        }

        .icon {
          font-size: 2rem;
          margin-bottom: 12px;
        }

        .shop-price {
          color: var(--violet-soft);
          font-weight: 900;
          font-size: 1.05rem;
        }

        .why-grid { grid-template-columns: repeat(3, 1fr); }

        .pay-card .label {
          display: inline-block;
          padding: 8px 12px;
          border-radius: 999px;
          background: rgba(187,114,255,0.14);
          border: 1px solid rgba(187,114,255,0.28);
          color: var(--violet-soft);
          font-size: 0.82rem;
          font-weight: 800;
          margin-bottom: 14px;
        }

        .category-shop {
          display: none;
          margin-top: 4px;
        }

        .category-shop.active { display: block; }

        .shop-shell { padding: 28px; }

        .shop-topbar {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 16px;
          flex-wrap: wrap;
          margin-bottom: 18px;
        }

        .shop-topbar h2 {
          font-size: clamp(1.5rem, 3vw, 2.4rem);
          margin-bottom: 8px;
        }

        .shop-controls {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 14px;
          flex-wrap: wrap;
          margin-bottom: 20px;
        }

        .shop-tab,
        .shop-filter,
        .cart-close {
          padding: 10px 16px;
          border-radius: 999px;
          border: 1px solid rgba(187,114,255,0.22);
          background: rgba(255,255,255,0.04);
          color: var(--text);
          cursor: pointer;
          font-weight: 800;
          font: inherit;
        }

        .shop-tab.active,
        .shop-filter.active {
          background: linear-gradient(180deg, #d692ff 0%, #a54bff 52%, #6d22da 100%);
          color: #12071d;
        }

        .mini-cart {
          display: flex;
          align-items: center;
          gap: 12px;
          flex-wrap: wrap;
          padding: 12px 16px;
          border-radius: 18px;
          background: rgba(255,255,255,0.04);
          border: 1px solid var(--line);
        }

        .mini-cart strong {
          color: var(--violet-soft);
        }

        .floating-cart-toggle {
          position: fixed;
          top: 18px;
          right: 150px;
          z-index: 120;
          display: flex;
          align-items: center;
          gap: 10px;
          padding: 12px 16px;
          border-radius: 16px;
          background: linear-gradient(180deg, rgba(28,18,43,0.98) 0%, rgba(15,10,24,0.98) 100%);
          border: 1px solid rgba(187,114,255,0.28);
          color: var(--text);
          box-shadow: var(--shadow);
          cursor: pointer;
          font-weight: 800;
          backdrop-filter: blur(14px);
          transition: transform 0.28s ease, box-shadow 0.28s ease;
        }

        .floating-cart-toggle:hover {
          transform: translateY(-2px);
          box-shadow: 0 18px 40px rgba(0,0,0,0.35);
        }

        .floating-cart-badge {
          min-width: 26px;
          height: 26px;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          border-radius: 999px;
          background: linear-gradient(180deg, #d692ff 0%, #a54bff 52%, #6d22da 100%);
          color: #12071d;
          padding: 0 8px;
          font-size: 0.85rem;
          font-weight: 900;
        }

        .floating-cart-panel {
          position: fixed;
          top: 88px;
          right: 32px;
          width: min(380px, calc(100vw - 24px));
          max-height: 70vh;
          overflow: auto;
          z-index: 119;
          display: block;
          opacity: 0;
          pointer-events: none;
          transform: translateY(-12px) scale(0.98);
          transform-origin: top right;
          background: linear-gradient(180deg, rgba(24,16,38,0.98), rgba(10,7,18,0.99));
          border: 1px solid rgba(187,114,255,0.24);
          border-radius: 24px;
          box-shadow: var(--shadow);
          padding: 18px;
          backdrop-filter: blur(14px);
          transition: opacity 0.24s ease, transform 0.24s ease;
        }

        .floating-cart-panel.open {
          opacity: 1;
          pointer-events: auto;
          transform: translateY(0) scale(1);
        }

        .cart-panel-top {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 12px;
          margin-bottom: 14px;
        }

        .cart-list {
          display: grid;
          gap: 12px;
          margin-bottom: 14px;
        }

        .cart-item {
          padding: 14px;
          border-radius: 18px;
          background: rgba(255,255,255,0.04);
          border: 1px solid var(--line);
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 12px;
        }

        .cart-item strong { display: block; margin-bottom: 4px; }

        .cart-item-price {
          color: var(--violet-soft);
          font-weight: 900;
          white-space: nowrap;
        }

        .cart-empty {
          color: var(--muted);
          padding: 12px 0 4px;
        }

        .cart-summary {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 12px;
          margin-top: 8px;
          padding-top: 12px;
          border-top: 1px solid rgba(255,255,255,0.08);
          color: var(--violet-soft);
          font-weight: 900;
        }

        .cart-panel-actions {
          display: flex;
          flex-direction: column;
          gap: 10px;
          margin-top: 10px;
        }

        .shop-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .shop-product {
          padding: 22px;
          display: flex;
          flex-direction: column;
          justify-content: space-between;
          min-height: 230px;
        }

        .badge-row {
          display: flex;
          gap: 8px;
          flex-wrap: wrap;
          margin-bottom: 10px;
        }

        .product-badge {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          padding: 6px 10px;
          border-radius: 999px;
          font-size: 0.78rem;
          font-weight: 800;
          border: 1px solid rgba(255,255,255,0.1);
          background: rgba(255,255,255,0.04);
          color: var(--text);
        }

        .product-badge.new {
          background: rgba(92, 255, 182, 0.12);
          color: #9fffd0;
          border-color: rgba(92, 255, 182, 0.25);
        }

        .product-badge.bestseller {
          background: rgba(255, 210, 110, 0.12);
          color: #ffd879;
          border-color: rgba(255, 210, 110, 0.24);
        }

        .product-badge.free,
        .product-badge.pro {
          background: rgba(187,114,255,0.12);
          color: #efccff;
          border-color: rgba(187,114,255,0.24);
        }

        .shop-meta {
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 12px;
          margin-top: 10px;
          flex-wrap: wrap;
        }

        .shop-empty {
          color: var(--muted);
          padding: 18px 0 4px;
        }

        .cta-box {
          grid-template-columns: 1.2fr 0.8fr;
          align-items: center;
          background: linear-gradient(180deg, rgba(27,16,42,0.98), rgba(10,7,18,0.98));
          border: 1px solid rgba(170, 91, 255, 0.18);
          padding: 32px;
        }

        .copy-box {
          background: #0c0814;
          border: 1px solid var(--line);
          color: var(--violet-soft);
          padding: 14px 16px;
          border-radius: 14px;
          font-weight: 800;
          flex: 1 1 210px;
        }

        footer {
          padding: 28px 0 38px;
          color: var(--muted);
        }

        .footer-grid {
          grid-template-columns: repeat(3, 1fr);
          padding-top: 18px;
          border-top: 1px solid var(--line);
        }

        .rules-modal {
          display: none;
          position: fixed;
          inset: 0;
          background: rgba(0,0,0,0.72);
          z-index: 999;
          align-items: center;
          justify-content: center;
          padding: 20px;
        }

        .rules-box {
          width: min(900px, 100%);
          max-height: 80vh;
          overflow: auto;
          background: #0b0714;
          border-radius: 20px;
          padding: 30px;
          border: 1px solid rgba(255,255,255,0.1);
          box-shadow: var(--shadow);
        }

        .rules-box h2 {
          color: #e4c0ff;
          margin-bottom: 20px;
        }

        .rules-box p {
          color: var(--muted);
          line-height: 1.8;
          margin-bottom: 10px;
        }

        .toast {
          position: fixed;
          right: 20px;
          bottom: 20px;
          z-index: 9999;
          display: none;
          background: #120a1d;
          color: #fff;
          border: 1px solid rgba(255,255,255,0.1);
          border-radius: 16px;
          padding: 14px 18px;
          box-shadow: 0 20px 50px rgba(0,0,0,0.35);
          font-weight: 700;
          max-width: 320px;
        }

        @media (max-width: 1080px) {
          .hero-grid,
          .cta-box,
          .payments-grid,
          .why-grid,
          .footer-grid,
          .shop-grid {
            grid-template-columns: 1fr;
          }

          .hero-grid > div:first-child {
            padding-left: 0;
            align-items: center;
          }

          .hero-card { margin-left: 0; }
          h1 { text-align: center; }
          .hero-actions { justify-content: center; }
          .shop-controls { flex-direction: column; align-items: stretch; }
          .nav-links { padding-right: 0; }
        }

        @media (max-width: 760px) {
          .nav {
            align-items: flex-start;
            flex-direction: column;
          }

          .hero {
            padding-top: 52px;
            min-height: auto;
          }

          .btn { width: 100%; }
          .hero-actions { flex-direction: column; }
          .shop-topbar { align-items: stretch; }
          .shop-tabs,
          .shop-filters,
          .trust-bar { flex-direction: column; }

          .floating-cart-toggle {
            top: auto;
            right: 12px;
            left: 12px;
            bottom: 12px;
            justify-content: center;
          }

          .floating-cart-panel {
            right: 12px;
            left: 12px;
            top: auto;
            bottom: 72px;
            width: auto;
            max-height: 58vh;
            transform-origin: bottom center;
          }
        }
    </style>
</head>
<body>
<header>
    <div class="container nav">
        <a href="#start" class="brand">
            <div class="logo-box" aria-hidden="true"></div>
            <div>
                <strong class="pixel">RUDYPLUGINS</strong>
                <span>Pluginy i skrypty Minecraft</span>
            </div>
        </a>

        <nav class="nav-links">
            <a href="#sklep-kategoria"></a>
            <a href="#platnosci">Płatności</a>
            <a href="#" onclick="copyInstagram(); return false;">Kontakt</a>
            <a href="https://tipply.pl/@oskareqs" target="_blank" rel="noopener" class="btn btn-primary">Kup teraz</a>
        </nav>
    </div>

    <div class="status-topbar" onclick="openRules()" style="cursor:pointer;">
        📜 Regulamin sklepu — kliknij
    </div>
</header>

<main id="start">
    <section class="hero">
        <div class="container hero-grid">
            <div>
                <div class="tag">⚡ Profesjonalne pluginy i skrypty dla serwerów Minecraft</div>
                <h1 class="pixel">RUDYPLUGINS — GOTOWE PRODUKTY NA TWÓJ SERWER</h1>
                <div class="hero-actions">
                    <a href="#sklep-kategoria" class="btn btn-primary">Zobacz produkty</a>
                    <a href="#platnosci" class="btn btn-secondary">Metody płatności</a>
                </div>
            </div>

            <div class="hero-card">
                <div class="shop-grid">
                    <article class="shop-product" onclick="openCategory('pluginy')" style="cursor:pointer;">
                        <div>
                            <div class="badge-row"><span class="product-badge new">NEW</span></div>
                            <h3>Pluginy Premium</h3>
                            <p>Autorskie darmowe i platne pluginy</p>
                        </div>
                        <div class="shop-meta">
                            <span class="shop-price"></span>
                        </div>
                    </article>

                    <article class="shop-product" onclick="openCategory('skrypty')" style="cursor:pointer;">
                        <div>
                            <div class="badge-row"><span class="product-badge bestseller">BESTSELLER</span></div>
                            <h3>Skrypty</h3>
                            <p>Autorskie darmowe i platne skrypty</p>
                        </div>
                        <div class="shop-meta">
                            <span class="shop-price"></span>
                        </div>
                    </article>

                    <article class="shop-product" onclick="openCategory('konfiguracje')" style="cursor:pointer;">
                        <div>
                            <div class="badge-row"><span class="product-badge pro">PRO</span></div>
                            <h3>Konfiguracje</h3>
                            <p>Tutaj macie konfiguracje pluginow itp</p>
                        </div>
                        <div class="shop-meta">
                            <span class="shop-price"></span>
                        </div>
                    </article>

                    <article class="shop-product" onclick="openCategory('bundle')" style="cursor:pointer;">
                        <div>
                            <div class="badge-row"><span class="product-badge bestseller">PAKIET</span></div>
                            <h3>Gotowe paczki</h3>
                            <p>Gotowe paczki pod server mc</p>
                        </div>
                        <div class="shop-meta">
                            <span class="shop-price"></span>
                        </div>
                    </article>
                </div>
            </div>
        </div>
    </section>

    <section id="sklep-kategoria" class="category-shop">
        <div class="container">
            <div class="shop-shell">
                <div class="shop-topbar">
                    <div>
                        <div class="tag" style="margin-bottom:10px;">🛒 Sklep</div>
                        <h2 id="shopCategoryTitle">Pluginy</h2>
                        <p class="section-lead" id="shopCategoryLead" style="text-align:left; margin:0; max-width:780px;">Wybierz darmowe albo płatne produkty i przejdź do zakupu.</p>
                    </div>
                    <div class="shop-tabs">
                        <button class="shop-tab active" id="tabFree" onclick="switchShopTab('free')">Darmowe</button>
                        <button class="shop-tab" id="tabPaid" onclick="switchShopTab('paid')">Płatne</button>
                        <button class="shop-tab" onclick="closeCategoryShop()">Zamknij</button>
                    </div>
                </div>

                <div class="shop-controls">
                    <div class="shop-filters">
                        <button class="shop-filter active" id="filterAll" onclick="setShopFilter('all')">Wszystkie</button>
                        <button class="shop-filter" id="filterNew" onclick="setShopFilter('new')">Nowe</button>
