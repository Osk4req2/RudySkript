    function updateCartUI() {
      const countEl = document.getElementById('cartCount');
      const totalEl = document.getElementById('cartTotal');
      const floatingCount = document.getElementById('floatingCartCount');
      const panelCount = document.getElementById('cartPanelCount');
      const panelTotal = document.getElementById('cartPanelTotal');
      const cartList = document.getElementById('cartList');
      const cartEmpty = document.getElementById('cartEmpty');

      const count = cartItems.length;
      const total = cartItems.reduce((sum, item) => sum + parsePrice(item.price), 0);
      const countText = count + (count === 1 ? ' produkt' : ' produktów');
      const totalText = total.toFixed(2).replace('.', ',') + ' zł';

      if (countEl) countEl.textContent = countText;
      if (totalEl) totalEl.textContent = totalText;
      if (floatingCount) floatingCount.textContent = String(count);
      if (panelCount) panelCount.textContent = countText;
      if (panelTotal) panelTotal.textContent = totalText;

      if (!cartList || !cartEmpty) return;

      if (!count) {
        cartList.innerHTML = '';
        cartEmpty.style.display = 'block';
        return;
      }

      const grouped = {};
      cartItems.forEach(item => {
        const key = item.name + '|' + item.price;
        if (!grouped[key]) grouped[key] = { ...item, qty: 0 };
        grouped[key].qty++;
      });

      cartEmpty.style.display = 'none';
      cartList.innerHTML = Object.values(grouped).map(item => `
        <div class="cart-item">
          <div>
            <strong>${escapeHtml(item.name)}</strong>
            <div class="muted">${item.price === '0 zł' ? 'Produkt darmowy' : 'Produkt płatny'} • Ilość: ${item.qty}</div>
          </div>
          <div style="display:flex; align-items:center; gap:10px;">
            <span class="cart-item-price">${escapeHtml(item.price)}</span>
          </div>
        </div>
      `).join('');
    }

