      const paidTab = document.getElementById('tabPaid');
      const filterAll = document.getElementById('filterAll');
      const filterNew = document.getElementById('filterNew');
      const filterBest = document.getElementById('filterBest');

      if (!shop || !grid) return;

      const rawItems = shop[currentShopTab] || [];
      const items = rawItems.filter(item =>
        currentShopFilter === 'all' ? true : (item.badges || []).includes(currentShopFilter)
      );

      title.textContent = shop.title;
      lead.textContent = shop.lead;
      freeTab.classList.toggle('active', currentShopTab === 'free');
      paidTab.classList.toggle('active', currentShopTab === 'paid');
      filterAll.classList.toggle('active', currentShopFilter === 'all');
      filterNew.classList.toggle('active', currentShopFilter === 'new');
      filterBest.classList.toggle('active', currentShopFilter === 'bestseller');

      if (!items.length) {
        grid.innerHTML = '';
        empty.style.display = 'block';
        updateCartUI();
        return;
      }

      empty.style.display = 'none';
      grid.innerHTML = items.map(item => {
        const badges = (item.badges || []).map(badge => {
          const label = badge === 'new' ? 'Nowy' : badge === 'bestseller' ? 'BESTSELLER' : 'Darmowy';
          return `<span class="product-badge ${badge}">${label}</span>`;
        }).join('');

        const action = item.price === '0 zł'
          ? `downloadFreeProduct('${escapeJsString(item.name)}')`
          : `addToCart('${escapeJsString(item.name)}', '${escapeJsString(item.price)}')`;

        return `
          <article class="shop-product">
            <div>
              <div class="badge-row">${badges}</div>
              <h3>${escapeHtml(item.name)}</h3>
              <p>${escapeHtml(item.desc)}</p>
